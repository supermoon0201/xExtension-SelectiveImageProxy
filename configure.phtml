<?php

declare(strict_types=1);

$targetFeedIds = FreshRSS_Context::userConf()->attributeArray('selective_image_proxy_target_feed_ids') ?? [];
$targetFeedIdsText = implode("\n", array_map('strval', $targetFeedIds));
$proxyUrl = FreshRSS_Context::userConf()->attributeString('selective_image_proxy_url') ?? 'https://images.example.com/?url=';
$schemeHttp = FreshRSS_Context::userConf()->attributeBool('selective_image_proxy_scheme_http') ?? true;
$schemeHttps = FreshRSS_Context::userConf()->attributeBool('selective_image_proxy_scheme_https') ?? false;
$schemeDefault = FreshRSS_Context::userConf()->attributeString('selective_image_proxy_scheme_default') ?? 'auto';
$schemeInclude = FreshRSS_Context::userConf()->attributeBool('selective_image_proxy_scheme_include') ?? false;
$urlEncode = FreshRSS_Context::userConf()->attributeBool('selective_image_proxy_url_encode') ?? true;
?>
<form action="<?= _url('extension', 'configure', 'e', urlencode($this->getName())) ?>" method="post" data-auto-leave-validation="1">
    <input type="hidden" name="_csrf" value="<?= FreshRSS_Auth::csrfToken() ?>" />

    <div class="form-group">
        <label class="group-name" for="target_feed_ids">目标订阅源 ID</label>
        <div class="group-controls">
            <textarea
                id="target_feed_ids"
                name="target_feed_ids"
                rows="8"
                cols="50"
                placeholder="例如：&#10;12&#10;34&#10;56"><?= htmlspecialchars($targetFeedIdsText, ENT_COMPAT, 'UTF-8') ?></textarea>
            <p>一行一个，或用空格 / 逗号 / 分号分隔。只有这些 feed ID 的文章图片会走代理。</p>
        </div>
    </div>

    <div class="form-group">
        <label class="group-name" for="proxy_url">图片代理前缀</label>
        <div class="group-controls">
            <input
                type="text"
                id="proxy_url"
                name="proxy_url"
                size="80"
                value="<?= htmlspecialchars($proxyUrl, ENT_COMPAT, 'UTF-8') ?>"
                placeholder="https://images.example.com/?url=" />
            <p>示例：<code>https://images.example.com/?url=</code></p>
        </div>
    </div>

    <div class="form-group">
        <label class="group-name">代理规则</label>
        <div class="group-controls">
            <label><input type="checkbox" name="scheme_http" value="1"<?= $schemeHttp ? ' checked="checked"' : '' ?> /> 代理 HTTP 图片</label><br />
            <label><input type="checkbox" name="scheme_https" value="1"<?= $schemeHttps ? ' checked="checked"' : '' ?> /> 代理 HTTPS 图片</label><br />
            <label><input type="checkbox" name="scheme_include" value="1"<?= $schemeInclude ? ' checked="checked"' : '' ?> /> 把协议头（http:// 或 https://）一并传给代理</label><br />
            <label><input type="checkbox" name="url_encode" value="1"<?= $urlEncode ? ' checked="checked"' : '' ?> /> 对原图 URL 做 rawurlencode</label>
        </div>
    </div>

    <div class="form-group">
        <label class="group-name" for="scheme_default">无协议 URL 的处理方式</label>
        <div class="group-controls">
            <select id="scheme_default" name="scheme_default">
                <option value="auto"<?= $schemeDefault === 'auto' ? ' selected="selected"' : '' ?>>auto</option>
                <option value="http"<?= $schemeDefault === 'http' ? ' selected="selected"' : '' ?>>http</option>
                <option value="https"<?= $schemeDefault === 'https' ? ' selected="selected"' : '' ?>>https</option>
                <option value="-"<?= $schemeDefault === '-' ? ' selected="selected"' : '' ?>>不代理</option>
            </select>
            <p>处理形如 <code>//cdn.example.com/a.jpg</code> 的地址。</p>
        </div>
    </div>

    <div class="form-group form-actions">
        <div class="group-controls">
            <button class="btn btn-important" type="submit">保存</button>
        </div>
    </div>
</form>
